{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@foundation/api#build": {
      "dependsOn": ["^build"],
      "passThroughEnv": [
        "DATABASE_URL",
        "NODE_ENV",
        "AUTH_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "ALLOWED_ORIGINS"
      ]
    },
    "@foundation/web#build": {
      "dependsOn": ["@foundation/api#build"],
      "passThroughEnv": ["AUTH_SECRET"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": ["transit"],
      "passThroughEnv": ["DATABASE_URL", "NODE_ENV"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "e2e": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["PLAYWRIGHT_*", "BASE_URL", "DATABASE_URL", "SEED_USER_EMAIL", "SEED_USER_PASSWORD"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    }
  }
}
